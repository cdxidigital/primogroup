# Environment Configuration for Primo Pools
NODE_ENV=production

# API Configuration
VITE_API_URL=https://api.primopools.com.au
API_PORT=5000

# Database (Optional - Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/primo_pools
DB_HOST=
DB_PORT=5432
DB_NAME=primo_pools
DB_USER=
DB_PASSWORD=

# Contact & Email
CONTACT_EMAIL=hello@primopools.com.au
COMPANY_PHONE=08-9331-8998

# SMTP Configuration (for contact form emails)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@primopools.com.au

# Analytics & Monitoring
VERCEL_ENV=production
ANALYTICS_ID=
GOOGLE_ANALYTICS_ID=

# Security
CORS_ORIGIN=https://primopools.com.au